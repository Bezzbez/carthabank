{
  "info": {
    "name": "E-Banking API",
    "description": "Complete E-Banking REST API — SecureBank",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",      "value": "http://localhost:5000/api" },
    { "key": "accessToken",  "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "accountId",    "value": "" },
    { "key": "toAccountNo",  "value": "" }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register",
          "event": [{ "listen": "test", "script": { "exec": [
            "const r = pm.response.json();",
            "if (r.accessToken) {",
            "  pm.collectionVariables.set('accessToken', r.accessToken);",
            "  pm.collectionVariables.set('refreshToken', r.refreshToken);",
            "}"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Smith\",\n  \"email\": \"jane.smith@example.com\",\n  \"password\": \"Password@123\",\n  \"phone\": \"+1555000001\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": [
            "const r = pm.response.json();",
            "if (r.accessToken) {",
            "  pm.collectionVariables.set('accessToken', r.accessToken);",
            "  pm.collectionVariables.set('refreshToken', r.refreshToken);",
            "}",
            "if (r.user?.accounts?.[0]) {",
            "  pm.collectionVariables.set('accountId', r.user.accounts[0].id);",
            "}"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"Client@1234\"\n}"
            }
          }
        },
        {
          "name": "Login (Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@ebank.com\",\n  \"password\": \"Admin@1234\"\n}"
            }
          }
        },
        {
          "name": "Get Current User (me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "👤 Users",
      "item": [
        {
          "name": "Get Dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/users/dashboard"
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/users/profile"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/users/profile",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Updated\",\n  \"phone\": \"+1555999888\"\n}"
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/users/password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"Client@1234\",\n  \"newPassword\": \"NewPass@456\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "🏦 Accounts",
      "item": [
        {
          "name": "List My Accounts",
          "event": [{ "listen": "test", "script": { "exec": [
            "const r = pm.response.json();",
            "if (r.accounts?.[0]) pm.collectionVariables.set('accountId', r.accounts[0].id);"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/accounts"
          }
        },
        {
          "name": "Get Account Detail",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/accounts/{{accountId}}"
          }
        },
        {
          "name": "Open New Account",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/accounts",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"savings\",\n  \"currency\": \"USD\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "💸 Transactions",
      "item": [
        {
          "name": "Step 1 — Request OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/transactions/otp/request"
          }
        },
        {
          "name": "Step 2 — Transfer Money",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/transactions/transfer",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fromAccountId\": \"{{accountId}}\",\n  \"toAccountNumber\": \"EB9876543210987654\",\n  \"amount\": 150.00,\n  \"description\": \"Rent payment\",\n  \"otpCode\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Pay Bill",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/transactions/bill-payment",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fromAccountId\": \"{{accountId}}\",\n  \"billerName\": \"Electricity (STEG)\",\n  \"billerReference\": \"TN-2024-001234\",\n  \"amount\": 85.50,\n  \"otpCode\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Transaction History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/transactions?page=1&limit=10&type=transfer",
              "query": [
                { "key": "page",  "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "type",  "value": "transfer" }
              ]
            }
          }
        },
        {
          "name": "Transaction History — Date Filter",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/transactions?startDate=2024-01-01&endDate=2024-12-31",
              "query": [
                { "key": "startDate", "value": "2024-01-01" },
                { "key": "endDate",   "value": "2024-12-31" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "🛡️ Admin",
      "item": [
        {
          "name": "Get Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/admin/stats"
          }
        },
        {
          "name": "List All Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/admin/users?page=1&limit=20&role=client",
              "query": [
                { "key": "page",  "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "role",  "value": "client" }
              ]
            }
          }
        },
        {
          "name": "Search Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/admin/users?search=john",
              "query": [{ "key": "search", "value": "john" }]
            }
          }
        },
        {
          "name": "Toggle User Status",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/admin/users/bbbbbbbb-0000-0000-0000-000000000002/status"
          }
        },
        {
          "name": "Monitor All Transactions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/admin/transactions?page=1&limit=20&status=completed",
              "query": [
                { "key": "page",   "value": "1" },
                { "key": "limit",  "value": "20" },
                { "key": "status", "value": "completed" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "❤️ Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    }
  ]
}
