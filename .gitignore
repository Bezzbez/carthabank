# ==============================================================================
# 🛑 SECURITY & SENSITIVE INFORMATION 🛑
# NEVER commit these files to version control. They contain passwords, API keys,
# and database credentials that hackers can use to compromise your system.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Environment Variables & Secrets
# ------------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*
!.env.example   # It's okay to commit the example template (ensure it has NO real passwords)

# ------------------------------------------------------------------------------
# 2. Certificates and Cryptographic Keys
# ------------------------------------------------------------------------------
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
*.keystore
*.jks

# ------------------------------------------------------------------------------
